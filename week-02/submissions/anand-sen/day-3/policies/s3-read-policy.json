{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListS3Bucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::anand-week2-s3-role-lab-955"
    },
    {
      "Sid": "AllowReadS3Objects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::anand-week2-s3-role-lab-955/*"
    }
  ]
}
